-- Seleciona todos os eventos com seus respectivos organizadores e locais
SELECT nome, data, horario, capacidade, descricao FROM Evento;



-- Seleciona eventos que ocorrem após o dia 1º de agosto de 2025, com capacidade maior que 500
SELECT nome, data, capacidade FROM Evento
WHERE data > '2025-08-01' AND capacidade > 500;



-- Exemplo de INNER JOIN entre Evento e Organizador
SELECT e.nome AS evento_nome, o.nome AS organizador_nome
FROM Evento e
INNER JOIN Organizador o ON e.id_organizador = o.id_organizador;



-- Seleciona todos os eventos de "Teatro" ordenados por data
SELECT nome, data FROM Evento
WHERE id_categoria = (SELECT id_categoria FROM CategoriaEvento WHERE nome_categoria = 'Teatro')
ORDER BY data;



-- Conta o número de eventos por categoria, mas apenas para categorias com mais de 2 eventos
SELECT id_categoria, COUNT(*) AS total_eventos
FROM Evento
GROUP BY id_categoria
HAVING COUNT(*) > 2;
